<div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
  <div class="card" style="width: 18rem;">
    <div class="card-body">
      <h5 class="card-title"><%=@article.new_record? ? 'New Article' : 'Edit Article'%> </h5>

      <%= form_with model: @article do |form| %>
        <div class="mb-3"> 
          <%= form.label :title, class: "form-label" %>
          <%= form.text_field :title, class: "form-control",placeholder:"Enter Title"%> 
          <% @article.errors.full_messages_for(:title).each do |message| %>
            <div><%= message %></div>
          <% end %>
        </div>

        <div class="mb-3">
          <%=form.label :body, class:"form-label"%>
          <%=form.text_area :body, class: "form-control" , placeholder: "Enter body"%>
          <% @article.errors.full_messages_for(:body).each do |message| %>
            <div><%= message %></div>
          <% end %>
          <%= form.label :status %><br>
           <%= form.select :status, Visible::VALID_STATUSES, selected: article.status || 'public' %>
        </div>
        
        <div class="mb-3 text-end me-2">
          <%= form.submit class: "btn btn-success" %> 
        </div>
      <% end %>
    </div>
  </div>
</div>